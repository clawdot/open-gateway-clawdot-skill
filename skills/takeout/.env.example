# ── 唯一必需注入：API_KEY（agent 身份，clw_）────────────────────────────────
# 缺 API_KEY 时脚本返回 RECOVERY[API_KEY_MISSING]，引导用户去注册页（CLAWDOT_SETUP_URL）
# 拿 key 后由 agent 写入本文件。GATEWAY_MCP_URL 没配也一并写（默认公网 MCP 端点）。
GATEWAY_MCP_URL=https://eleme-gateway.hicaspian.com/mcp/v1
API_KEY=your-api-key

# ── 用户授权 consent_grant（cg_，= 一个用户）：正常流程不用配置本节 ────────────
# 模型：一个 api_key 可服务多个用户，一个 cg 表示一个用户。开局只需注入 API_KEY；
# cg 由用户本人走一次 SMS/H5 授权后，写入【共享凭证缓存】~/.clawdot/credentials.json
# （按 API_KEY+手机号键控，同一 API_KEY 下所有 skill 共用、skill 升级重装不丢绑定），
# 之后单用户业务命令无需 --phone。
#
#   首跑任意业务命令 → RECOVERY[USER_NOT_BOUND_NEEDS_SMS] →
#     短信（默认）：request_user_bind --phone <11位> → verify_user_bind --phone <11位> --bind-id --code
#     H5 链接：     request_user_bind --auth-type h5 --phone <11位> → verify_user_bind --auth-type h5 --request-id
#
# CONSENT_GRANT_ID 是【只读预注入】项：仅无状态部署直接喂长效 cg 跳过绑定时才需要；
# CLI 不会回写本文件。多用户场景各自绑定、业务调用带 --phone 指定。
# 注意：open-gateway 无 admin 静默绑定——每个用户必须本人授权一次。
# CONSENT_GRANT_ID=

# ── 可选 ────────────────────────────────────────────────────────────────────
# 共享凭证缓存目录（默认 ~/.clawdot；容器/多租户部署可重定向）
# CLAWDOT_HOME=/path/to/home

# API_KEY 缺失时引导用户注册/登录的页面地址（默认 ClawDot 控制台登录页）
# CLAWDOT_SETUP_URL=https://console.hicaspian.com/login

# 单用户模式冷启动用的兜底坐标（账号还没有任何 saved 地址时）；多用户模式忽略
DEFAULT_LAT=31.2304
DEFAULT_LNG=121.4737
