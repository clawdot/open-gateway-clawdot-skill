# ── 唯一必需注入：API_KEY（agent 身份，clw_）────────────────────────────────
# 缺 API_KEY 时脚本返回 RECOVERY[API_KEY_MISSING]，引导用户去注册页（CLAWDOT_SETUP_URL）
# 拿 key 后由 agent 写入本文件。GATEWAY_URL 没配也一并写。
GATEWAY_URL=https://clawdot.hicaspian.com/gateway
API_KEY=your-api-key

# ── 用户授权 CONSENT_GRANT_ID（cg_，= 一个用户 = 旧 user_token）：开局留空 ──────
# 模型：一个 api_key 可服务多个用户，一个 cg 表示一个用户。开局只需注入 API_KEY；
# cg 由用户本人走一次 SMS/H5 授权后，脚本【自动回写】到下面这行，之后无需再带 --phone。
#
#   首跑任意业务 action → RECOVERY[USER_NOT_BOUND_NEEDS_SMS] →
#     短信（默认）：request_code --phone <11位> → verify_code --phone <11位> --bind-id --code
#     H5 链接：     request_code --auth-type h5 --phone <11位> → verify_code --auth-type h5 --request-id
#   verify 成功 → cg 自动写入本文件 CONSENT_GRANT_ID（cg 90 天有效，到期/轮换重绑会覆盖回写）。
#
# 留空即可（绑定后自动填）；也可手动预注入一个长效 cg 跳过绑定（无状态部署）。
CONSENT_GRANT_ID=
#
# 多用户（一个安装服务多个用户）：每个用户各自绑定，业务调用带 --phone <11位> 指定用户
# （按手机号缓存 file / 可选 Redis）。env 里的 cg = 默认/最近绑定的那个用户。
# 注意：open-gateway 无 admin 静默绑定——每个用户必须本人授权一次（旧 ADMIN_SECRET/trustedBind 已移除）。

# ── 可选 ────────────────────────────────────────────────────────────────────
# API_KEY 缺失时引导用户注册/登录的页面地址（默认 ClawDot developer 登录页）
# CLAWDOT_SETUP_URL=https://clawdot.hicaspian.com/developer/login

# 跨进程共享按手机号缓存的 consent_grant（多用户高频调用建议开）
# REDIS_URL=redis://127.0.0.1:6379/0

# Personal 模式冷启动用的兜底坐标（账号还没有任何 saved 地址时）；用户绑定模式忽略
DEFAULT_LAT=31.2304
DEFAULT_LNG=121.4737
