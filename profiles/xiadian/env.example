# ── 必填 ──────────────────────────────────────────────────────────────
# open-gateway 的 agent API key（clw_…）。写进 skill 的 .env，install.sh 会落位。
API_KEY=

# ── 可选 ──────────────────────────────────────────────────────────────
# MCP 端点；默认线上，不用改
# GATEWAY_MCP_URL=https://eleme-gateway.hicaspian.com/mcp/v1
# 共享凭证缓存目录（容器/多租户部署重定向到挂载卷；默认 ~/.clawdot）
# CLAWDOT_HOME=
# 模型 key（install.sh 配 DeepSeek 时用；换别的模型自行改 install.sh 的 provider 段）
DEEPSEEK_API_KEY=
