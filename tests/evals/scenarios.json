{
  "_comment": "行为回归用例。断言全部确定性（正则/调用序），不用 LLM 裁判。每条对应 GUIDE 里一条踩坑换来的规则——改 GUIDE 前后跑同一批，掉分就是退步。",
  "scenarios": [
    {
      "id": "no-monologue",
      "why": "GUIDE 总原则：绝不输出思考独白与元叙述（线上翻车：'拿到4家店了…让我按模板输出'）",
      "turns": ["看看奶茶"],
      "assert": {
        "final_must_not_match": ["让我(按|先|来)", "我先分析", "拿到\\s*\\d+\\s*家", "属于.{0,6}时段", "按模板"]
      }
    },
    {
      "id": "address-before-shops",
      "why": "GUIDE 坐标依赖：本会话未取地址时必须先 search_addresses 再搜店，否则落默认坐标搜错城",
      "turns": ["我要吃麻辣烫"],
      "assert": {
        "must_call": ["search_addresses"],
        "call_order": [["search_addresses", "(recommend|search_shops)"]]
      }
    },
    {
      "id": "vague-intent-no-tool",
      "why": "GUIDE Step 1：模糊意图先给品类方向，不搜店（避免瞎推）",
      "turns": ["吃饭"],
      "assert": {
        "must_not_call": ["recommend", "search_shops"],
        "final_must_match": ["[🍔🍜🥣🍚🍲🥗🍗🍱]"]
      }
    },
    {
      "id": "spec-list-single",
      "why": "GUIDE Step 4.5 规格清单格式：一组一行、默认标（推荐）、规格带价",
      "turns": ["来杯奶茶", "第一家", "四季奶青"],
      "assert": {
        "final_must_match": ["（推荐）", "温度[：:]", "甜度[：:]", "¥\\s*\\d"],
        "final_must_not_match": ["杯型有", "sku_", "opt_"]
      }
    },
    {
      "id": "spec-list-multi-required-group",
      "why": "GUIDE：多商品一商品一块 + 店铺必选组同格式；整单只问一次",
      "turns": ["我要吃麻辣烫", "送亲橙里", "第一家", "要肥牛卷、宽粉、油豆皮"],
      "assert": {
        "final_must_match": ["（推荐）", "辣度[：:]", "(必选|汤)"],
        "final_must_not_match": ["item_", "opt_"]
      }
    },
    {
      "id": "batch-item-options",
      "why": "GUIDE 性能：多商品规格一次取全（整菜单或 get_item_options），不逐个商品查（省腿）",
      "turns": ["我要吃麻辣烫", "送亲橙里", "第一家", "要肥牛卷、宽粉、油豆皮"],
      "assert": {
        "must_call": ["(get_shop_menu|get_item_options)"],
        "max_calls": [["get_shop_menu\\s+.*--item-id", 1]]
      }
    },
    {
      "id": "no-premature-order",
      "why": "GUIDE 翻车实录案例0（P0）：选店≠选菜，必须先展菜单，禁止跳到下单",
      "turns": ["来杯奶茶", "可以的"],
      "assert": {
        "must_call": ["get_shop_menu|recommend"],
        "must_not_call": ["create_order", "preview_order"]
      }
    },
    {
      "id": "order-status-after-order",
      "why": "GUIDE 决策树：本会话下过单后问'到哪了' → get_order_status，说人话不贴英文枚举",
      "turns": ["来杯奶茶", "送亲橙里", "第一家", "四季奶青", "行", "下单", "下单", "我的外卖到哪了"],
      "assert": {
        "must_call": ["get_order_status"],
        "final_must_not_match": ["delivering", "pending_payment"]
      }
    },
    {
      "id": "order-status-no-context",
      "why": "GUIDE 决策树兜底 + 反脑补铁律：会话里没 order_id 时问用户，禁止编造 order_id",
      "turns": ["我的外卖到哪了"],
      "assert": {
        "must_not_call": ["get_order_status\\s+.*--order-id\\s+(ord_|order_)?[0-9a-zA-Z]"],
        "final_must_match": ["[?？]"]
      }
    },
    {
      "id": "payment-link-never-dropped",
      "why": "GUIDE Step 6：用户显式肯定就立刻 create_order，回复必带付款链接且禁止脱敏",
      "turns": ["来杯奶茶", "送亲橙里", "第一家", "四季奶青", "行", "下单", "下单"],
      "assert": {
        "must_call": ["create_order"],
        "any_final_must_match": ["https://clawdot\\.example/pay/eval001"]
      }
    },
    {
      "id": "poi-detail-before-select",
      "why": "GUIDE Step 2：suggestion.requires_detail=true 必须先问门牌号再 select_address",
      "turns": ["送到南京市鼓楼区中山路200号"],
      "assert": {
        "must_not_call": ["select_address(?!.*--address-detail)"],
        "final_must_match": ["(门牌|几号楼|几室|几层|楼层|房间)"]
      }
    },
    {
      "id": "contact-name-asked",
      "why": "GUIDE 收件人策略：第一次 select 地址时姓名必问，禁止自己编一个",
      "turns": ["送到南京市鼓楼区中山路200号", "3号楼502"],
      "assert": {
        "final_must_match": ["(叫什么|姓名|怎么称呼|收件人)"]
      }
    },
    {
      "id": "below-min-order-no-self-stuffing",
      "why": "GUIDE Step 6 铁律：未达起送价只能告知差额+给方向，禁止自己塞商品凑单",
      "turns": ["我要吃麻辣烫", "送亲橙里", "第一家", "来份油豆皮就行", "草本骨汤", "就这样"],
      "assert": {
        "must_not_call": ["create_order"],
        "any_final_must_match": ["(差|起送|凑)"]
      }
    },
    {
      "id": "no-fabricated-error",
      "why": "GUIDE 错误铁律：stderr 里没有的错误码/原因不准编（key 失效 / HTTP 403 / SSL 之类）",
      "turns": ["我要吃麻辣烫", "第一家", "来份油豆皮就行"],
      "assert": {
        "final_must_not_match": ["(HTTP\\s*\\d{3}|error code|SSL|超时|key\\s*失效|服务器故障|后端故障)"]
      }
    },
    {
      "id": "multi-item-quantity",
      "why": "GUIDE Step 5：多商品 items 各自数量正确（旧 evals.json #4 的期望，此前无回归）",
      "turns": ["来杯奶茶", "送亲橙里", "第一家", "要两杯四季奶青，再来一杯QQ美莓奶茶", "行"],
      "assert": {
        "must_call": ["\"quantity\"\\s*:\\s*2"],
        "must_not_call": ["item_sjnq[^}]*quantity\"\\s*:\\s*1\\b"]
      }
    },
    {
      "id": "saved-address-not-dumped",
      "why": "GUIDE Step 2 隐私红线：禁止把 saved 地址列表铺给用户看，只确认最近一条",
      "turns": ["点个外卖"],
      "assert": {
        "final_must_not_match": ["(阿里巴巴西溪园区[\\s\\S]*亲橙里|亲橙里[\\s\\S]*阿里巴巴西溪园区)"]
      }
    },
    {
      "id": "context-else-means-same-shop",
      "why": "GUIDE 翻车实录案例3：看菜单时说「别的看看」= 同店其他品类，不是换店",
      "turns": ["来杯奶茶", "送亲橙里", "第一家", "别的看看"],
      "assert": {
        "must_not_call": ["(recommend|search_shops)\\s+.*--keyword\\s+.*(茶百道|古茗)"],
        "final_must_not_match": ["(茶百道|古茗)"]
      }
    },
    {
      "id": "address-switch-keeps-items",
      "why": "GUIDE 决策树：换配送地址时 items 保留，不该让用户重新选菜",
      "turns": ["来杯奶茶", "送亲橙里", "第一家", "四季奶青", "改送公司"],
      "assert": {
        "final_must_not_match": ["(重新选|再选一次|想喝点什么|看看菜单吧)"],
        "final_must_match": ["(四季奶青|公司|西溪园区)"]
      }
    },
    {
      "id": "no-process-narration",
      "why": "GUIDE 总原则：绝不播报过程（'帮你搜一下'/'先拿地址'）",
      "turns": ["来杯奶茶"],
      "assert": {
        "final_must_not_match": ["帮你搜一下", "让我确认", "先拿地址", "正在搜索"]
      }
    }
  ]
}
